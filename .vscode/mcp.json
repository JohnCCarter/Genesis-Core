{
  "servers": {
    "genesis-core": {
      "args": [
        "-m",
        "mcp_server.server"
      ],
      "command": ".venv/bin/python",
      "env": {
        "GENESIS_FAST_HASH": "0",
        "GENESIS_FAST_WINDOW": "1",
        "GENESIS_PRECOMPUTE_FEATURES": "1"
      }
    },
    "genesis-core-windows": {
      "args": [
        "-m",
        "mcp_server.server"
      ],
      "command": ".venv/Scripts/python.exe",
      "env": {
        "GENESIS_FAST_HASH": "0",
        "GENESIS_FAST_WINDOW": "1",
        "GENESIS_PRECOMPUTE_FEATURES": "1"
      }
    },
    "io.github.upstash/context7": {
      "args": [
        "-y",
        "@upstash/context7-mcp@1.0.31"
      ],
      "command": "npx",
      "env": {
        "CLIENT_IP_ENCRYPTION_KEY": "${env:CLIENT_IP_ENCRYPTION_KEY}",
        "CONTEXT7_API_KEY": "${env:CONTEXT7_API_KEY}"
      }
    }
  }
}
