{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis-core.local/schemas/strategy_candidate_manifest.schema.json",
  "title": "Genesis-Core Strategy Candidate Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_type", "registry_version", "candidates"],
  "properties": {
    "manifest_type": { "const": "strategy_candidates" },
    "registry_version": { "type": "integer", "minimum": 1, "maximum": 1 },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "symbol",
          "timeframe",
          "strategy_family",
          "config_path",
          "created_at",
          "governance_refs",
          "evidence_refs"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
          "status": {
            "type": "string",
            "enum": [
              "research",
              "candidate",
              "promotion_compare",
              "champion_freeze"
            ]
          },
          "symbol": { "type": "string", "minLength": 1 },
          "timeframe": { "type": "string", "minLength": 1 },
          "strategy_family": { "type": "string", "enum": ["legacy", "ri"] },
          "config_path": {
            "type": "string",
            "pattern": "^config/strategy/candidates(?:/[A-Za-z0-9._-]+)+\\.json$"
          },
          "created_at": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "governance_refs": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^docs/.*\\.md$"
            }
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^(docs/.*\\.md|results/.*|artifacts/.*)$"
            }
          },
          "lineage": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "parent_candidate_id": {
                "type": "string",
                "pattern": "^[a-z0-9_-]+$"
              },
              "source_run": { "type": "string", "minLength": 1 },
              "source_trial": { "type": "string", "minLength": 1 }
            }
          },
          "notes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
